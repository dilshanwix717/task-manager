# Production environment for docker-compose.prod.yml.
# On the server:  cp .env.prod.example .env  then fill in real values.
# The real .env is gitignored — never commit actual secrets.

# --- database ---
DB_USER=taskuser
DB_PASSWORD=change_me_to_a_long_random_password
DB_NAME=task_tracker

# --- auth ---
# generate with:  openssl rand -base64 48
JWT_SECRET=change_me_to_a_long_random_secret
ACCESS_TOKEN_EXPIRATION=1d

# --- seeded admin account (change the password!) ---
ADMIN_USER_NAME=admin
ADMIN_EMAIL=admin@tasktracker.dev
ADMIN_PASSWORD=change_me_admin_password

# --- public site url (used for CORS + socket.io origin) ---
# the address users open in the browser, e.g. http://<EC2_PUBLIC_IP>
PUBLIC_URL=http://localhost
